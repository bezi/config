# Multiplex connections through one socket, 10min persist
ControlMaster auto
ControlPath /tmp/%r@%h:%p
ControlPersist 10m

Host *
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 3

Host piplup
    Hostname piplup.bezi.io
    User bezi

Host homelab
    Hostname homelab-bastion
    User bezi
